{
  "name": "@raxora/tokens",
  "version": "0.1.0",
  "type": "module",
  "description": "Raxora Design tokens — single source of truth for all visual decisions",
  "exports": {
    ".": {
      "import": "./dist/js/index.js",
      "types": "./dist/js/index.d.ts"
    },
    "./css": "./dist/css/tokens.css",
    "./css/core": "./dist/css/core.css",
    "./css/light": "./dist/css/themes/light.css",
    "./css/dark": "./dist/css/themes/dark.css",
    "./css/dim": "./dist/css/themes/dim.css",
    "./css/high-contrast-light": "./dist/css/themes/high-contrast-light.css",
    "./css/high-contrast-dark": "./dist/css/themes/high-contrast-dark.css",
    "./css/themes/light": "./dist/css/themes/light.css",
    "./css/themes/dark": "./dist/css/themes/dark.css",
    "./css/themes/dim": "./dist/css/themes/dim.css",
    "./css/themes/high-contrast-light": "./dist/css/themes/high-contrast-light.css",
    "./css/themes/high-contrast-dark": "./dist/css/themes/high-contrast-dark.css",
    "./tailwind": "./dist/tailwind/theme.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch"
  },
  "devDependencies": {
    "@tokens-studio/sd-transforms": "^2.0.3",
    "chokidar": "^5.0.0",
    "style-dictionary": "^4.4.0"
  }
