{
  "$metadata": {
    "type": "semantic",
    "theme": "high-contrast-dark",
    "description": "High-contrast dark theme semantic overrides. Same keys as dark, tuned for stronger separation and accessibility."
  },
  "semantic": {
    "color": {
      "background": {
        "page": { "$type": "color", "$value": "{color.gray.900}" },
        "surface": { "$type": "color", "$value": "{color.gray.800}" },
        "subtle": { "$type": "color", "$value": "{color.gray.700}" },
        "muted": { "$type": "color", "$value": "{color.gray.600}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{color.white}" },
        "secondary": { "$type": "color", "$value": "{color.gray.100}" },
        "heading": { "$type": "color", "$value": "{color.black.500}" },
        "disabled": { "$type": "color", "$value": "{color.gray.500}" },
        "inverse": { "$type": "color", "$value": "{color.gray.900}" },
        "link": { "$type": "color", "$value": "{color.blue.300}" },
        "link-hover": { "$type": "color", "$value": "{color.blue.200}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{color.gray.600}" },
        "strong": { "$type": "color", "$value": "{color.gray.500}" },
        "focus": { "$type": "color", "$value": "{color.orange.400}" },
        "disabled": { "$type": "color", "$value": "{color.gray.600}" }
      },
      "feedback": {
        "success-bg": { "$type": "color", "$value": "{color.green.900}" },
        "success-text": { "$type": "color", "$value": "{color.green.300}" },
        "success-border": { "$type": "color", "$value": "{color.green.700}" },
        "warning-bg": { "$type": "color", "$value": "{color.yellow.900}" },
        "warning-text": { "$type": "color", "$value": "{color.yellow.300}" },
        "warning-border": { "$type": "color", "$value": "{color.yellow.700}" },
        "danger-bg": { "$type": "color", "$value": "{color.red.900}" },
        "danger-text": { "$type": "color", "$value": "{color.red.300}" },
        "danger-border": { "$type": "color", "$value": "{color.red.700}" },
        "info-bg": { "$type": "color", "$value": "{color.blue.900}" },
        "info-text": { "$type": "color", "$value": "{color.blue.300}" },
        "info-border": { "$type": "color", "$value": "{color.blue.700}" }
      },
      "action": {
        "primary-bg": { "$type": "color", "$value": "{color.orange.400}" },
        "primary-bg-hover": {
          "$type": "color",
          "$value": "{color.orange.500}"
        },
        "primary-bg-active": {
          "$type": "color",
          "$value": "{color.orange.600}"
        },
        "primary-bg-disabled": {
          "$type": "color",
          "$value": "{color.gray.700}"
        },
        "primary-text": { "$type": "color", "$value": "{color.white}" },
        "primary-text-disabled": {
          "$type": "color",
          "$value": "{color.gray.500}"
        },
        "secondary-bg": { "$type": "color", "$value": "{color.gray.700}" },
        "secondary-bg-hover": {
          "$type": "color",
          "$value": "{color.gray.600}"
        },
        "secondary-bg-active": {
          "$type": "color",
          "$value": "{color.gray.500}"
        },
        "secondary-text": { "$type": "color", "$value": "{color.gray.100}" },
        "secondary-border": { "$type": "color", "$value": "{color.gray.600}" },
        "ghost-bg-hover": { "$type": "color", "$value": "{color.gray.700}" },
        "ghost-text": { "$type": "color", "$value": "{color.gray.100}" },
        "danger-bg": { "$type": "color", "$value": "{color.red.500}" },
        "danger-bg-hover": { "$type": "color", "$value": "{color.red.400}" },
        "danger-bg-active": { "$type": "color", "$value": "{color.red.300}" },
        "danger-text": { "$type": "color", "$value": "{color.white}" }
      }
    }
  }
}
