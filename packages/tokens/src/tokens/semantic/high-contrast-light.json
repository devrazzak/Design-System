{
  "$metadata": {
    "type": "semantic",
    "theme": "high-contrast-light",
    "description": "High-contrast light theme semantic overrides. Same keys as light, tuned for stronger separation and accessibility."
  },
  "semantic": {
    "color": {
      "background": {
        "page": { "$type": "color", "$value": "{color.white}" },
        "surface": { "$type": "color", "$value": "{color.gray.50}" },
        "subtle": { "$type": "color", "$value": "{color.gray.100}" },
        "muted": { "$type": "color", "$value": "{color.gray.200}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{color.gray.900}" },
        "secondary": { "$type": "color", "$value": "{color.gray.800}" },
        "heading": { "$type": "color", "$value": "{color.black.500}" },
        "disabled": { "$type": "color", "$value": "{color.gray.500}" },
        "inverse": { "$type": "color", "$value": "{color.white}" },
        "link": { "$type": "color", "$value": "{color.blue.700}" },
        "link-hover": { "$type": "color", "$value": "{color.blue.800}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{color.gray.400}" },
        "strong": { "$type": "color", "$value": "{color.gray.600}" },
        "focus": { "$type": "color", "$value": "{color.orange.700}" },
        "disabled": { "$type": "color", "$value": "{color.gray.300}" }
      },
      "feedback": {
        "success-bg": { "$type": "color", "$value": "{color.green.50}" },
        "success-text": { "$type": "color", "$value": "{color.green.800}" },
        "success-border": { "$type": "color", "$value": "{color.green.300}" },
        "warning-bg": { "$type": "color", "$value": "{color.yellow.50}" },
        "warning-text": { "$type": "color", "$value": "{color.yellow.800}" },
        "warning-border": { "$type": "color", "$value": "{color.yellow.300}" },
        "danger-bg": { "$type": "color", "$value": "{color.red.50}" },
        "danger-text": { "$type": "color", "$value": "{color.red.800}" },
        "danger-border": { "$type": "color", "$value": "{color.red.300}" },
        "info-bg": { "$type": "color", "$value": "{color.blue.50}" },
        "info-text": { "$type": "color", "$value": "{color.blue.800}" },
        "info-border": { "$type": "color", "$value": "{color.blue.300}" }
      },
      "action": {
        "primary-bg": { "$type": "color", "$value": "{color.orange.600}" },
        "primary-bg-hover": {
          "$type": "color",
          "$value": "{color.orange.700}"
        },
        "primary-bg-active": {
          "$type": "color",
          "$value": "{color.orange.800}"
        },
        "primary-bg-disabled": {
          "$type": "color",
          "$value": "{color.gray.200}"
        },
        "primary-text": { "$type": "color", "$value": "{color.white}" },
        "primary-text-disabled": {
          "$type": "color",
          "$value": "{color.gray.500}"
        },
        "secondary-bg": { "$type": "color", "$value": "{color.gray.50}" },
        "secondary-bg-hover": {
          "$type": "color",
          "$value": "{color.gray.100}"
        },
        "secondary-bg-active": {
          "$type": "color",
          "$value": "{color.gray.200}"
        },
        "secondary-text": { "$type": "color", "$value": "{color.gray.800}" },
        "secondary-border": { "$type": "color", "$value": "{color.gray.400}" },
        "ghost-bg-hover": { "$type": "color", "$value": "{color.gray.100}" },
        "ghost-text": { "$type": "color", "$value": "{color.gray.800}" },
        "danger-bg": { "$type": "color", "$value": "{color.red.600}" },
        "danger-bg-hover": { "$type": "color", "$value": "{color.red.700}" },
        "danger-bg-active": { "$type": "color", "$value": "{color.red.800}" },
        "danger-text": { "$type": "color", "$value": "{color.white}" }
      }
    }
  }
}
