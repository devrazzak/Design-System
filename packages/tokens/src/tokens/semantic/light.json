{
  "$metadata": {
    "type": "semantic",
    "theme": "light",
    "description": "Semantic tokens map purpose to primitive values. These are what components consume. Change themes by swapping these mappings."
  },
  "semantic": {
    "color": {
      "background": {
        "page": {
          "$type": "color",
          "$value": "{color.white}"
        },
        "surface": {
          "$type": "color",
          "$value": "{color.gray.50}"
        },
        "subtle": {
          "$type": "color",
          "$value": "{color.gray.100}"
        },
        "muted": {
          "$type": "color",
          "$value": "{color.gray.200}"
        },
        "inverse": {
          "$type": "color",
          "$value": "{color.gray.900}"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{color.gray.900}",
          "$description": "Main body text"
        },
        "secondary": {
          "$type": "color",
          "$value": "{color.gray.700}",
          "$description": "Supporting text"
        },
        "tertiary": {
          "$type": "color",
          "$value": "{color.gray.500}",
          "$description": "Placeholder, disabled text"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.gray.400}",
          "$description": "Disabled text"
        },
        "inverse": {
          "$type": "color",
          "$value": "{color.white}",
          "$description": "Text on dark backgrounds"
        },
        "link": {
          "$type": "color",
          "$value": "{color.secondary.600}",
          "$description": "Hyperlinks"
        },
        "link-hover": {
          "$type": "color",
          "$value": "{color.secondary.700}",
          "$description": "Hyperlink hover"
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "{color.gray.200}",
          "$description": "Default borders"
        },
        "strong": {
          "$type": "color",
          "$value": "{color.gray.300}",
          "$description": "Stronger borders"
        },
        "focus": {
          "$type": "color",
          "$value": "{color.primary.500}",
          "$description": "Focus ring color"
        },
        "disabled": {
          "$type": "color",
          "$value": "{color.gray.200}",
          "$description": "Disabled border"
        }
      },
      "action": {
        "primary-bg": {
          "$type": "color",
          "$value": "{color.primary.500}",
          "$description": "Primary button background"
        },
        "primary-bg-hover": {
          "$type": "color",
          "$value": "{color.primary.600}",
          "$description": "Primary button hover"
        },
        "primary-bg-active": {
          "$type": "color",
          "$value": "{color.primary.700}",
          "$description": "Primary button pressed"
        },
        "primary-bg-disabled": {
          "$type": "color",
          "$value": "{color.gray.200}",
          "$description": "Primary button disabled"
        },
        "primary-text": {
          "$type": "color",
          "$value": "{color.white}",
          "$description": "Text on primary button"
        },
        "primary-text-disabled": {
          "$type": "color",
          "$value": "{color.gray.400}",
          "$description": "Disabled button text"
        },

        "secondary-bg": {
          "$type": "color",
          "$value": "{color.white}",
          "$description": "Secondary button background"
        },
        "secondary-bg-hover": {
          "$type": "color",
          "$value": "{color.gray.50}",
          "$description": "Secondary button hover"
        },
        "secondary-bg-active": {
          "$type": "color",
          "$value": "{color.gray.100}",
          "$description": "Secondary button pressed"
        },
        "secondary-border": {
          "$type": "color",
          "$value": "{color.gray.300}",
          "$description": "Secondary button border"
        },
        "secondary-text": {
          "$type": "color",
          "$value": "{color.gray.900}",
          "$description": "Text on secondary button"
        },

        "ghost-bg-hover": {
          "$type": "color",
          "$value": "{color.gray.100}",
          "$description": "Ghost button hover"
        },
        "ghost-text": {
          "$type": "color",
          "$value": "{color.gray.700}",
          "$description": "Ghost button text"
        },

        "danger-bg": {
          "$type": "color",
          "$value": "{color.danger.500}",
          "$description": "Danger button background"
        },
        "danger-bg-hover": {
          "$type": "color",
          "$value": "{color.danger.600}",
          "$description": "Danger button hover"
        },
        "danger-bg-active": {
          "$type": "color",
          "$value": "{color.danger.700}",
          "$description": "Danger button pressed"
        },
        "danger-text": {
          "$type": "color",
          "$value": "{color.white}",
          "$description": "Text on danger button"
        }
      },
      "feedback": {
        "success-bg": { "$type": "color", "$value": "{color.success.50}" },
        "success-text": { "$type": "color", "$value": "{color.success.700}" },
        "success-border": { "$type": "color", "$value": "{color.success.200}" },
        "warning-bg": { "$type": "color", "$value": "{color.warning.50}" },
        "warning-text": { "$type": "color", "$value": "{color.warning.700}" },
        "warning-border": { "$type": "color", "$value": "{color.warning.200}" },
        "danger-bg": { "$type": "color", "$value": "{color.danger.50}" },
        "danger-text": { "$type": "color", "$value": "{color.danger.700}" },
        "danger-border": { "$type": "color", "$value": "{color.danger.200}" },
        "info-bg": { "$type": "color", "$value": "{color.secondary.50}" },
        "info-text": { "$type": "color", "$value": "{color.secondary.700}" },
        "info-border": { "$type": "color", "$value": "{color.secondary.200}" }
      }
    }
  }
}
