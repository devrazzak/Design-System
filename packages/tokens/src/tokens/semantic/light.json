{
  "$metadata": {
    "type": "semantic",
    "theme": "light",
    "description": "Semantic tokens map purpose to primitive values. These are what components consume. Change themes by swapping these mappings."
  },
  "semantic": {
    "color": {
      "background": {
        "page": { "$type": "color", "$value": "{color.white}" },
        "surface": { "$type": "color", "$value": "{color.gray.50}" },
        "subtle": { "$type": "color", "$value": "{color.gray.100}" },
        "muted": { "$type": "color", "$value": "{color.gray.200}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{color.gray.900}" },
        "secondary": { "$type": "color", "$value": "{color.gray.700}" },
        "heading": { "$type": "color", "$value": "{color.black.500}" },
        "disabled": { "$type": "color", "$value": "{color.gray.400}" },
        "inverse": { "$type": "color", "$value": "{color.white}" },
        "link": { "$type": "color", "$value": "{color.blue.600}" },
        "link-hover": { "$type": "color", "$value": "{color.blue.700}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{color.gray.200}" },
        "strong": { "$type": "color", "$value": "{color.gray.300}" },
        "focus": { "$type": "color", "$value": "{color.orange.500}" },
        "disabled": { "$type": "color", "$value": "{color.gray.200}" }
      },
      "feedback": {
        "success-bg": { "$type": "color", "$value": "{color.green.50}" },
        "success-text": { "$type": "color", "$value": "{color.green.700}" },
        "success-border": { "$type": "color", "$value": "{color.green.200}" },
        "warning-bg": { "$type": "color", "$value": "{color.yellow.50}" },
        "warning-text": { "$type": "color", "$value": "{color.yellow.700}" },
        "warning-border": { "$type": "color", "$value": "{color.yellow.200}" },
        "danger-bg": { "$type": "color", "$value": "{color.red.50}" },
        "danger-text": { "$type": "color", "$value": "{color.red.700}" },
        "danger-border": { "$type": "color", "$value": "{color.red.200}" },
        "info-bg": { "$type": "color", "$value": "{color.blue.50}" },
        "info-text": { "$type": "color", "$value": "{color.blue.700}" },
        "info-border": { "$type": "color", "$value": "{color.blue.200}" }
      },
      "action": {
        "primary-bg": { "$type": "color", "$value": "{color.orange.500}" },
        "primary-bg-hover": {
          "$type": "color",
          "$value": "{color.orange.600}"
        },
        "primary-bg-active": {
          "$type": "color",
          "$value": "{color.orange.700}"
        },
        "primary-bg-disabled": {
          "$type": "color",
          "$value": "{color.gray.200}"
        },
        "primary-text": { "$type": "color", "$value": "{color.white}" },
        "primary-text-disabled": {
          "$type": "color",
          "$value": "{color.gray.400}"
        },
        "secondary-bg": { "$type": "color", "$value": "{color.gray.50}" },
        "secondary-bg-hover": {
          "$type": "color",
          "$value": "{color.gray.100}"
        },
        "secondary-bg-active": {
          "$type": "color",
          "$value": "{color.gray.200}"
        },
        "secondary-text": { "$type": "color", "$value": "{color.gray.700}" },
        "secondary-border": { "$type": "color", "$value": "{color.gray.300}" },
        "ghost-bg-hover": { "$type": "color", "$value": "{color.gray.100}" },
        "ghost-text": { "$type": "color", "$value": "{color.gray.700}" },
        "danger-bg": { "$type": "color", "$value": "{color.red.500}" },
        "danger-bg-hover": { "$type": "color", "$value": "{color.red.600}" },
        "danger-bg-active": { "$type": "color", "$value": "{color.red.700}" },
        "danger-text": { "$type": "color", "$value": "{color.white}" }
      }
    }
  }
}
