{
  "$metadata": {
    "type": "component",
    "description": "Component-specific tokens. Reference semantic tokens only — never primitives. These allow per-component theming without touching other components."
  },
  "component": {
    "button": {
      "$description": "Button component tokens",
      "border-radius": { "$type": "dimension", "$value": "{radius.md}" },
      "font-weight": {
        "$type": "fontWeight",
        "$value": "{font.weight.medium}"
      },
      "gap": { "$type": "dimension", "$value": "{space.2}" },
      "transition-duration": {
        "$type": "duration",
        "$value": "{motion.duration.fast}"
      },
      "focus-ring-width": { "$type": "dimension", "$value": "3px" },

      "size": {
        "sm": {
          "height": { "$type": "dimension", "$value": "{size.control-sm}" },
          "padding-inline": { "$type": "dimension", "$value": "{space.3}" },
          "padding-block": { "$type": "dimension", "$value": "{space.1}" },
          "font-size": { "$type": "dimension", "$value": "{font.size.sm}" }
        },
        "md": {
          "height": { "$type": "dimension", "$value": "{size.control-md}" },
          "padding-inline": { "$type": "dimension", "$value": "{space.4}" },
          "padding-block": { "$type": "dimension", "$value": "{space.2}" },
          "font-size": { "$type": "dimension", "$value": "{font.size.sm}" }
        },
        "lg": {
          "height": { "$type": "dimension", "$value": "{size.control-lg}" },
          "padding-inline": { "$type": "dimension", "$value": "{space.6}" },
          "padding-block": { "$type": "dimension", "$value": "{space.3}" },
          "font-size": { "$type": "dimension", "$value": "{font.size.md}" }
        }
      },

      "variant": {
        "primary": {
          "bg": {
            "$type": "color",
            "$value": "{semantic.color.action.primary-bg}"
          },
          "bg-hover": {
            "$type": "color",
            "$value": "{semantic.color.action.primary-bg-hover}"
          },
          "bg-active": {
            "$type": "color",
            "$value": "{semantic.color.action.primary-bg-active}"
          },
          "bg-disabled": {
            "$type": "color",
            "$value": "{semantic.color.action.primary-bg-disabled}"
          },
          "text": {
            "$type": "color",
            "$value": "{semantic.color.action.primary-text}"
          },
          "text-disabled": {
            "$type": "color",
            "$value": "{semantic.color.action.primary-text-disabled}"
          },
          "border": { "$type": "color", "$value": "transparent" }
        },
        "secondary": {
          "bg": {
            "$type": "color",
            "$value": "{semantic.color.action.secondary-bg}"
          },
          "bg-hover": {
            "$type": "color",
            "$value": "{semantic.color.action.secondary-bg-hover}"
          },
          "bg-active": {
            "$type": "color",
            "$value": "{semantic.color.action.secondary-bg-active}"
          },
          "text": {
            "$type": "color",
            "$value": "{semantic.color.action.secondary-text}"
          },
          "border": {
            "$type": "color",
            "$value": "{semantic.color.action.secondary-border}"
          }
        },
        "ghost": {
          "bg": { "$type": "color", "$value": "transparent" },
          "bg-hover": {
            "$type": "color",
            "$value": "{semantic.color.action.ghost-bg-hover}"
          },
          "text": {
            "$type": "color",
            "$value": "{semantic.color.action.ghost-text}"
          },
          "border": { "$type": "color", "$value": "transparent" }
        },
        "danger": {
          "bg": {
            "$type": "color",
            "$value": "{semantic.color.action.danger-bg}"
          },
          "bg-hover": {
            "$type": "color",
            "$value": "{semantic.color.action.danger-bg-hover}"
          },
          "bg-active": {
            "$type": "color",
            "$value": "{semantic.color.action.danger-bg-active}"
          },
          "text": {
            "$type": "color",
            "$value": "{semantic.color.action.danger-text}"
          },
          "border": { "$type": "color", "$value": "transparent" }
        }
      }
    }
  }
}
