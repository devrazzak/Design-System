{
  "$metadata": {
    "type": "core",
    "description": "Spacing scale — 4px base unit"
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0", "$description": "0px" },
    "1": { "$type": "dimension", "$value": "4px", "$description": "4px" },
    "2": { "$type": "dimension", "$value": "8px", "$description": "8px" },
    "3": { "$type": "dimension", "$value": "12px", "$description": "12px" },
    "4": { "$type": "dimension", "$value": "16px", "$description": "16px" },
    "5": { "$type": "dimension", "$value": "20px", "$description": "20px" },
    "6": { "$type": "dimension", "$value": "24px", "$description": "24px" },
    "8": { "$type": "dimension", "$value": "32px", "$description": "32px" },
    "10": { "$type": "dimension", "$value": "40px", "$description": "40px" },
    "12": { "$type": "dimension", "$value": "48px", "$description": "48px" },
    "16": { "$type": "dimension", "$value": "64px", "$description": "64px" }
  },
  "radius": {
    "none": { "$type": "dimension", "$value": "0" },
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "6px" },
    "lg": { "$type": "dimension", "$value": "8px" },
    "xl": { "$type": "dimension", "$value": "12px" },
    "full": { "$type": "dimension", "$value": "9999px" }
  },
  "size": {
    "control-sm": {
      "$type": "dimension",
      "$value": "32px",
      "$description": "Minimum touch target small"
    },
    "control-md": {
      "$type": "dimension",
      "$value": "40px",
      "$description": "Default control height"
    },
    "control-lg": {
      "$type": "dimension",
      "$value": "48px",
      "$description": "Large control height"
    }
  }
}
