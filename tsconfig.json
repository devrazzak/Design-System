{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "paths": {
      "@raxora/tokens": ["./packages/tokens/src/index.ts"],
      "@raxora/tokens/css": ["./packages/tokens/dist/css/tokens.css"],
      "@raxora/react": ["./packages/react/src/index.ts"],
      "@raxora/react/*": ["./packages/react/src/*"]
    }
  },
  "include": ["packages/*/src"],
  "exclude": ["**/node_modules", "**/dist"]
}
